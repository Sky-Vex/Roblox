-- 4. 将所有物品贴图改成指定图片（使用第一个图片ID作为替换图）
local replacementImage = imageIds[1]  -- 用第一张图片替换所有贴图

-- 递归遍历并修改所有带有 Image / TextureId 属性的实例
local function replaceTextures(instance)
	local success, result = pcall(function()
		if instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
			instance.Image = replacementImage
		elseif instance:IsA("Decal") or instance:IsA("Texture") then
			instance.Texture = replacementImage
		elseif instance:IsA("BillboardGui") or instance:IsA("SurfaceGui") then
			-- 无需处理，继续遍历子级
		elseif instance:IsA("Part") or instance:IsA("MeshPart") then
			-- 可能包含贴花，遍历子级
		end
	end)
	if not success then
		warn("替换贴图时出错:", result)
	end

	for _, child in ipairs(instance:GetChildren()) do
		replaceTextures(child)
	end
end

-- 首次遍历整个数据模型
replaceTextures(game)

-- 监听新加入的对象，立即替换贴图
game.DescendantAdded:Connect(function(descendant)
	replaceTextures(descendant)
end)

