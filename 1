local currentSongIndex = 1
local function playNextSong()
	currentSongIndex = currentSongIndex % #songIds + 1
	sound.SoundId = songIds[currentSongIndex]
	-- 延迟一小段时间再播放，确保 SoundId 生效
	task.wait(0.1)
	sound:Play()
end

sound.Ended:Connect(playNextSong)

