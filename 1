-- 2. 循环播放歌曲（确保音量足够，并处理播放失败情况）
local sound = Instance.new("Sound")
sound.SoundId = songIds[1]  -- 先设为第一首
sound.Looped = false        -- 用 Ended 事件实现循环
sound.Volume = 1            -- 最大音量
